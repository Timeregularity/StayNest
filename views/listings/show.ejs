<% layout("layouts/boilerplate") %>

<body>
   <% if(error && error.length){ %>
      <div class="alert alert-danger alert-dismissible fade show col-10 col-md-6 mx-auto mt-3" role="alert">
         <%= error[0] %>
         <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
   <% } %>

   <% if(listing) { %>
   <div class="container show-page">

      <div class="card show-card">
         <img src="<%= (listing.img.url && (typeof listing.img === 'string' ? listing.img : listing.img.url)) || 'https://via.placeholder.com/300x200?text=Image+Not+Available' %>" class="card-img-top show-img" alt="image">

         <div class="card-body">
            <h2 class="card-title"><%= listing.title %></h2>
            <p class="card-text"><%= listing.description %>.</p>
            <p class="card-text">₹ <%= listing.price.toLocaleString("en-IN") %>/night</p>
            <p class="card-text"><%= listing.location %></p>
            <p class="card-text"><%= listing.country %></p>
            <p class="card-text">Owned By <%= listing.owner ? listing.owner.username : 'Unknown' %></p>

            <% if(currentUser && listing.owner && listing.owner._id.toString() == currentUser._id.toString()) { %>
               <div class="show-actions">
                  <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark">Edit</a>

                  <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST">
                     <button class="btn btn-dark">Delete this Listing</button>
                  </form>
               </div>
            <% } %>
         </div>
      </div>

      <hr>

      <% if(currentUser){ %>
      <div class="review-form-section mb-4 mt-3">
         <h3>Leave a review</h3>
         <form novalidate class="needs-validation" action="/listings/<%= listing._id %>/reviews" method="post">
            <div class="mt-2">
               <label for="Rating">Rating:</label>
               <input class="form-control" name="review[rating]" type="range" min="1" max="5">
            </div>

            <div class="mb-2 mt-3">
               <label for="comment">Comment:</label>
               <textarea name="review[comment]" class="form-control" id="comment" rows="5" cols="30"></textarea>
            </div>

            <div class="mb-2" style="display: none;">
               <label for="author">Author:</label>
               <input class="form-control" name="review[author]" type="text" value="<%= currentUser._id %>">
            </div>

            <button class="btn btn-outline-dark">Submit</button>
         </form>
      </div>
      <% } %>

      <hr>

      <div class="avg-review">
         <%
            let total = 0;
            let length = listing.reviews.length;

            for(let ratings of listing.reviews){
               total += ratings.rating;
            }

            let avg = length > 0 ? (total / length).toFixed(1) : 0;
         %>

         <h1><%= avg %></h1>
         <span style="color: rgb(255, 242, 0); font-size: 18pt;">
            <% for (let i = 1; i <= avg; i++) { %>
               <%= '★' %>
            <% } %>

            <% if(avg % 1 != 0){ %>
               <%= '⯪' %>
            <% } %>

            <% for (let i = 1; i <= 5 - avg; i++) { %>
               <%= '☆' %>
            <% } %>
         </span>

         <h6>Total Reviews: <%= length %></h6>
      </div>

      <h3 class="mt-4">All Reviews</h3>

      <div class="reviews-list">
         <% for(let ratings of listing.reviews){ %>
            <div class="card border mb-3 mt-3">
               <div class="card-body">
                  <b>Rating: </b>
                  <span style="color: rgb(255, 242, 0); font-size: 18pt;">
                     <% for (let i = 1; i <= 5; i++) { %>
                        <%= i <= ratings.rating ? '★' : '☆' %>
                     <% } %>
                  </span>
                  <br>

                  <b>Remarks: </b><%= ratings.comment %><br>

                  <span style="font-size: 10pt;">
                     <%= ratings.createdAt ? ratings.createdAt.toDateString() : "" %>
                  </span>

                  <form action="/listings/<%= listing._id %>/reviews/<%= ratings._id %>?_method=DELETE" method="POST" class="mt-2">
                     <button class="btn btn-outline-dark btn-sm">Delete</button>
                  </form>
               </div>
            </div>
         <% } %>
      </div>

   </div>
   <% } %>
</body>